DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Admin
ADMIN_PASSCODE="your-secure-admin-passcode"
ADMIN_EMAIL="admin@yourdomain.com"

# Public site URL (used for metadata and sitemap)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"

# Meeting link shown to hospitals that request an onboarding call
MEETING_LINK="https://cal.com/your-link"

# Gmail OAuth2 (for outbound notifications via Nodemailer)
GMAIL_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
GMAIL_CLIENT_SECRET="your-google-oauth-client-secret"
GMAIL_REFRESH_TOKEN="your-gmail-oauth-refresh-token"

# Google Sheets (Service Account JSON — paste the full JSON as a single line)
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
GOOGLE_SHEET_ID="google-sheet-id-for-vacancy-submissions"
CANDIDATES_SHEET_ID="google-sheet-id-for-candidate-applications"
